{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "darkText": "#d0d0d0",
    "darkMuted": "#808080",
    "darkRed": "#ff5f5f",
    "darkGreen": "#5fd75f",
    "darkYellow": "#ffd75f",
    "darkBlue": "#5fafff",
    "darkMagenta": "#d75fff",
    "darkCyan": "#5fd7d7",
    "darkOrange": "#ff8700",
    "darkLineNumber": "#5c5c5c",

    "lightText": "#1a1a1a",
    "lightMuted": "#6a6a6a",
    "lightRed": "#cc0000",
    "lightGreen": "#008700",
    "lightYellow": "#af8700",
    "lightBlue": "#0066cc",
    "lightMagenta": "#8700af",
    "lightCyan": "#007878",
    "lightOrange": "#d75f00",
    "lightLineNumber": "#9a9a9a"
  },
  "theme": {
    "primary": { "dark": "darkBlue", "light": "lightBlue" },
    "secondary": { "dark": "darkCyan", "light": "lightCyan" },
    "accent": { "dark": "darkOrange", "light": "lightOrange" },

    "success": { "dark": "darkGreen", "light": "lightGreen" },
    "error": { "dark": "darkRed", "light": "lightRed" },
    "warning": { "dark": "darkYellow", "light": "lightYellow" },
    "info": { "dark": "darkCyan", "light": "lightCyan" },

    "text": { "dark": "darkText", "light": "lightText" },
    "textMuted": { "dark": "darkMuted", "light": "lightMuted" },
    "conceal": { "dark": "darkMuted", "light": "lightMuted" },

    "background": { "dark": "transparent", "light": "transparent" },
    "backgroundPanel": { "dark": "#0e1116cc", "light": "#f5f5f5e6" },
    "backgroundElement": { "dark": "transparent", "light": "transparent" },

    "border": { "dark": "darkMuted", "light": "lightMuted" },
    "borderActive": { "dark": "darkBlue", "light": "lightBlue" },
    "borderSubtle": { "dark": "darkLineNumber", "light": "lightLineNumber" },

    "diffAdded": { "dark": "darkGreen", "light": "lightGreen" },
    "diffRemoved": { "dark": "darkRed", "light": "lightRed" },
    "diffContext": { "dark": "darkMuted", "light": "lightMuted" },
    "diffHunkHeader": { "dark": "darkCyan", "light": "lightCyan" },
    "diffHighlightAdded": { "dark": "darkGreen", "light": "lightGreen" },
    "diffHighlightRemoved": { "dark": "darkRed", "light": "lightRed" },
    "diffAddedBg": { "dark": "#23452f", "light": "#d8f0de" },
    "diffRemovedBg": { "dark": "#45232b", "light": "#f7d9dd" },
    "diffAddedWordBg": { "dark": "#356b46", "light": "#a6dab6" },
    "diffRemovedWordBg": { "dark": "#6b353f", "light": "#f0b3bd" },
    "diffContextBg": { "dark": "transparent", "light": "transparent" },
    "diffLineNumber": { "dark": "darkLineNumber", "light": "lightLineNumber" },
    "diffAddedLineNumberBg": { "dark": "#2c5639", "light": "#bce4c6" },
    "diffRemovedLineNumberBg": { "dark": "#562c35", "light": "#f2c3c9" },

    "syntaxComment": { "dark": "darkMuted", "light": "lightMuted" },
    "syntaxKeyword": { "dark": "darkMagenta", "light": "lightMagenta" },
    "syntaxFunction": { "dark": "darkBlue", "light": "lightBlue" },
    "syntaxVariable": { "dark": "darkRed", "light": "lightRed" },
    "syntaxString": { "dark": "darkGreen", "light": "lightGreen" },
    "syntaxNumber": { "dark": "darkOrange", "light": "lightOrange" },
    "syntaxType": { "dark": "darkYellow", "light": "lightYellow" },
    "syntaxOperator": { "dark": "darkCyan", "light": "lightCyan" },
    "syntaxPunctuation": { "dark": "darkText", "light": "lightText" },

    "markdownText": { "dark": "darkText", "light": "lightText" },
    "markdownHeading": { "dark": "darkBlue", "light": "lightBlue" },
    "markdownLink": { "dark": "darkCyan", "light": "lightCyan" },
    "markdownLinkText": { "dark": "darkBlue", "light": "lightBlue" },
    "markdownCode": { "dark": "darkGreen", "light": "lightGreen" },
    "markdownBlockQuote": { "dark": "darkMuted", "light": "lightMuted" },
    "markdownEmph": { "dark": "darkYellow", "light": "lightYellow" },
    "markdownStrong": { "dark": "darkOrange", "light": "lightOrange" },
    "markdownHorizontalRule": { "dark": "darkMuted", "light": "lightMuted" },
    "markdownListItem": { "dark": "darkMagenta", "light": "lightMagenta" },
    "markdownListEnumeration": { "dark": "darkOrange", "light": "lightOrange" },
    "markdownImage": { "dark": "darkCyan", "light": "lightCyan" },
    "markdownImageText": { "dark": "darkBlue", "light": "lightBlue" },
    "markdownCodeBlock": { "dark": "darkText", "light": "lightText" }
  }
}
